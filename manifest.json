{
  "manifest_version": 3,
  "name": "Feegow",
  "version": "5.0",
  "description": "Ajustes Feegow",
  "update_url": "https://github.com/ictbraseg/feegow-extension-chrome-update/update.xml",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": [
        "*://*.feegow.com/*",
        "*://feegow.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]

}
